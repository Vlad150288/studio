---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { servicess } from "../../../data/services";

const lang = "ua";
const docs = servicess.documents;

const lead =
  "Термінове фото на документи за 10–15 хвилин. Ви зможете отримати фото на паспорт, права, шенгенську візу, грін карту США (green card USA), дитячий біометричний паспорт та інші документи, у кольоровому або чорно-білому варіанті, на матовому або глянцевому фотопапері, відповідно до Ваших бажань або вимог інстанції. Кількість зображень на блоці залежить від розміру потрібної фотографії. Нижче ми наводимо найбільш затребувані.";
---

<BaseLayout title="Реставрація фото — Focus">
  <div class="doc-page">
    <section class="doc-info">


          <div class="doc-row">
            <div class="doc-main-desc">
              <div>
                <h2 class="service-title">РЕСТАВРАЦІЯ ФОТО</h2>
                <p class="doc-main-subtitle">Реставрація виконується вручну з використанням сучасних цифрових технологій</p>

                <ul class="services-list">
                  <li class="doc-item">Подряпини та заломи</li>
                  <!-- <li class="doc-item">Плями та вигоряння</li> -->
                  <!-- <li class="doc-item">Вицвілі кольори</li> -->
                  <li class="doc-item">Розмитість та втрату чіткості</li>
                  <li class="doc-item">Пошкоджені краї фото</li>
                </ul>
              </div>

              <div class="doc-meta" aria-label="Умови послуги">
                <span class="doc-chip doc-chip--price">від 6 грн / шт</span>
                <span class="doc-chip doc-chip--time">5–15 хв</span>
                <span class="doc-chip doc-chip--file">з телефону / флешки</span>
              </div>

            </div>
            <div class="doc-row-media">
              <img src="/images/restore.jpg" alt="Реставрація фото: до та після"  loading="lazy" width="500" height="310"/>
            </div>
          </div> 

        </section>


        <!-- <div class="doc-line"></div> -->
        <div class="main-page-line"></div>




        <section class="doc-info-restore">  
          <h2 class="doc-block-title">ПРИКЛАДИ РЕСТАВРОВАНИХ ФОТО</h2>
          <p class="doc-lead how-rest__lead">До і після реставрації старих пошкодженних фото</p>      

          <div class="row-restore">
            <div class="doc-main-desc">
              <div>
                <h2 class="service-title">ВІДНОВЛЕННЯ ПОШКОДЖЕНЬ</h2>
                <p class="doc-main-subtitle">Відновимо старі та пошкоджені фото акуратно та природно</p>

                <ul class="services-list">
                  <li class="doc-item">Приберемо подряпини, заломи</li>
                  <li class="doc-item">Повернемо чіткість і тон (колір/ч-б)</li>
                  <li class="doc-item">Підготуємо файл для друку</li>
                </ul>
              </div>
              <div class="doc-meta" aria-label="Умови послуги">
                <span class="doc-chip doc-chip--price">від 300 грн</span>
              </div>
            </div>

            <div class="doc-row-media">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>

            <div class="doc-row-media hide-img">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>
          </div>        
        </section>

        <section class="doc-info-restore hide-block">        
          <div class="row-restore">
            <div class="doc-row-media">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>

            <div class="doc-row-media">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>

            <div class="doc-main-desc">
              <div>
                <h2 class="service-title">РОЗФАРБУВАТИ ФОТО </h2>
                <p class="doc-main-subtitle">Відновимо старі та пошкоджені фото акуратно та природно</p>

                <ul class="services-list">
                  <li class="doc-item">Приберемо подряпини, заломи</li>
                  <li class="doc-item">Повернемо чіткість і тон (колір/ч-б)</li>
                  <li class="doc-item">Підготуємо файл для друку</li>
                </ul>
              </div>
              <div class="doc-meta" aria-label="Умови послуги">
                <span class="doc-chip doc-chip--price">від 300 грн</span>
              </div>
            </div>
          </div>        
    </section>

            <section class="doc-info-restore">        
          <div class="row-restore">
            <div class="doc-main-desc">
              <div>
                <h2 class="service-title">ВІДНОВЛЕННЯ ПОШКОДЖЕНЬ</h2>
                <p class="doc-main-subtitle">Відновимо старі та пошкоджені фото акуратно та природно</p>

                <ul class="services-list">
                  <li class="doc-item">Приберемо подряпини, заломи</li>
                  <li class="doc-item">Повернемо чіткість і тон (колір/ч-б)</li>
                  <li class="doc-item">Підготуємо файл для друку</li>
                </ul>
              </div>
              <div class="doc-meta" aria-label="Умови послуги">
                <span class="doc-chip doc-chip--price">від 300 грн</span>
              </div>
            </div>

            <div class="doc-row-media">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>

            <div class="doc-row-media hide-img">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>
          </div>        
        </section>
        <div class="main-page-line"></div>
       

  <section class="doc-info how-rest">
  <div class="doc-header">
    <h2 class="doc-block-title">ЯК ПРОХОДИТЬ РЕСТАВРАЦІЯ</h2>
    <!-- <div class="doc-line"></div> -->
      <!-- <div class="main-page-line"></div> -->
    <p class="doc-lead how-rest__lead">
      Простий процес: ви приносите фото — ми оцінюємо — відновлюємо — ви отримуєте готовий результат.
    </p>
  </div>

  <div class="how-rest__row">
    <!-- LEFT (25%) -->
    <div class="doc-main-desc how-rest__left">
      <h3 class="service-title how-rest__title">Етапи роботи</h3>
      <p class="doc-main-subtitle how-rest__sub">
        Оцінка займає 3–5 хв. Остаточну ціну скажемо після огляду фото.
      </p>

      <ul class="services-list how-rest__mini">
        <li class="doc-item">Без спотворення облич та деталей</li>
        <li class="doc-item">Ручна реставрація + цифрові технології</li>
        <li class="doc-item">Підготовка до друку за потреби</li>
      </ul>
    </div>

    <!-- RIGHT (75%) -->
    <div class="doc-desc how-rest__right">
      <div class="how-rest__steps">

        <div class="how-rest__step">
          <div class="how-rest__num">1</div>
          <div class="how-rest__text">
            <div class="how-rest__step-title">Принесіть фото</div>
            <div class="how-rest__step-desc">
              Можна одне або кілька. Підкажемо, що реально відновити.
            </div>
          </div>
        </div>

        <div class="how-rest__step">
          <div class="how-rest__num">2</div>
          <div class="how-rest__text">
            <div class="how-rest__step-title">Оцінюємо складність</div>
            <div class="how-rest__step-desc">
              Скажемо термін і вартість після огляду (зазвичай 3–5 хв).
            </div>
          </div>
        </div>

        <div class="how-rest__step">
          <div class="how-rest__num">3</div>
          <div class="how-rest__text">
            <div class="how-rest__step-title">Реставруємо вручну</div>
            <div class="how-rest__step-desc">
              Прибираємо дефекти, відновлюємо деталі, тон і контраст.
            </div>
          </div>
        </div>

        <div class="how-rest__step">
          <div class="how-rest__num">4</div>
          <div class="how-rest__text">
            <div class="how-rest__step-title">Видаємо результат</div>
            <div class="how-rest__step-desc">
              Отримаєте відреставроване фото та (за потреби) файл для друку.
            </div>
          </div>
        </div>

      </div>


    </div>
  </div>
        <div class="how-rest__note">
        💡 Вартість залежить від пошкоджень та обсягу роботи. Остаточну ціну скажемо після огляду фото.
      </div>
</section>


    <!-- <div class="main-page-line"></div> -->

    <section class="why">
  <div class="why-header">
    <h2 class="why-title">ЧОМУ ОБИРАЮТЬ НАС</h2>
    <div class="why-line"></div>
  </div>

  <div class="why-row">
    <article class="why-card">
      <div class="why-ico why-ico--rules" aria-hidden="true"></div>
      <div class="why-card-title">Реставрація вручну</div>
      <div class="why-card-sub">(без “пластика”)</div>

      <div class="why-meta">
        <span class="doc-chip doc-chip--file">природний результат</span>
      </div>
    </article>

    <article class="why-card">
      <div class="why-ico why-ico--print" aria-hidden="true"></div>
      <div class="why-card-title">Під друк</div>
      <div class="why-card-sub">(чіткість / тон)</div>

      <div class="why-meta">
        <span class="doc-chip doc-chip--file">підготовка файлу</span>
      </div>
    </article>

    <article class="why-card">
      <div class="why-ico why-ico--fast" aria-hidden="true"></div>
      <div class="why-card-title">Терміни по фото</div>
      <div class="why-card-sub">(після огляду)</div>

      <div class="why-meta">
        <span class="doc-chip doc-chip--time">скажемо одразу</span>
      </div>
    </article>
  </div>

  <div class="why-cta">
    <div class="why-cta-text">Зателефонуйте або напишіть у Viber/Telegram</div>
    <div class="why-cta-icons" aria-hidden="true">
      <span class="why-app why-app--viber"></span>
      <span class="why-app why-app--tg"></span>
    </div>
  </div>
</section>


    <script type="application/json" id="docs-data" set:html={JSON.stringify(docs)}></script>
  </div>
</BaseLayout>
