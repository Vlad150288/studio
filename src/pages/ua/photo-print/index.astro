      <div class="faq">
        {faq.map((item) => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <div class="faq-a">{item.a}</div>
          </details>
        ))}
      </div>

    </section>


    <section class="why">
  <div class="why-header">
    <h2 class="why-title">ЧОМУ ОБИРАЮТЬ НАС</h2>
    <div class="why-line"></div>
  </div>

  <div class="why-row">
