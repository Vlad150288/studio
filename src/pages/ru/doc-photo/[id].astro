---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { servicess } from "../../../data/services";

const lang = "ru";

export function getStaticPaths() {
  return servicess.documents.map(item => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<BaseLayout title={`${item.title[lang]} — Focus`}>
  <article class="service">
    <h1>{item.title[lang]}</h1>
    <img src={item.image} alt={item.title[lang]} width="720" height="480" />

    <p>{item.desc[lang]}</p>

    <div class="priceBox">
      <p>{item.prices.standard[lang]}: <b>{item.prices.standard.value} грн</b></p>
      <p>{item.prices.express[lang]}: <b>{item.prices.express.value} грн</b></p>
    </div>

    <p><a href="/ru/" data-astro-prefetch>← Назад к услугам</a></p>
  </article>
</BaseLayout>
