---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { servicess } from "../../data/services";

const lang = "ru";
const docs = servicess.documents;

const lead =
  "Термінове фото на документи за 10–15 хвилин. Ви зможете отримати фото на паспорт, права, шенгенську візу, грін карту США (green card USA), дитячий біометричний паспорт та інші документи, у кольоровому або чорно-білому варіанті, на матовому або глянцевому фотопапері, відповідно до Ваших бажань або вимог інстанції. Кількість зображень на блоці залежить від розміру потрібної фотографії.";
---

<BaseLayout title="Фотостудія Focus">
  <div class="doc-page">
    <!-- DOC PHOTO (preview) -->
    <section class="doc-info">        
          <div class="doc-row" data-title={docs[0].title[lang]}>
            <div class="doc-main-desc">
              <div>
              <h2 class="service-title">ФОТО НА ДОКУМЕНТИ</h2>

              <p class="doc-main-subtitle">Термінове фото на всі види документів за 10–15 хвилин</p>

              <ul class="services-list">
                <li class="doc-item">Фото за 10–15 хвилин</li>
                <li class="doc-item">Будь-які розміри (паспорт, віза, Green Card USA тощо)</li>
                <li class="doc-item">Підставимо костюм, військову або поліцейську форму</li>
                <!-- <li class="doc-item">Ретуш та вирівнювання фону за потреби</li> -->
              </ul>

              <div class="doc-meta" aria-label="Умови послуги">
                <span class="doc-chip doc-chip--price">від 150 грн</span>
                <span class="doc-chip doc-chip--time">10–15 хв</span>
                <span class="doc-chip doc-chip--file">файл на телефон / друк</span>
              </div>
            </div>

              <a class="doc-more" href="/ua/doc-photo/">
                <span class="doc-more__label">Детальніше</span>
                <span class="doc-more__text">про фото на документи</span>
              </a>
            </div>

            <div class="doc-image">
              <img src="/images/111.jpg" alt={docs[0].title[lang]}  height="345" loading="lazy" />
            </div>
          </div>        

      <script type="application/json" id="docs-data" set:html={JSON.stringify(docs)}></script>
    </section>

    <div class="main-page-line"></div>

    <!-- RESTORE (preview) -->
    <section class="doc-info">        
          <div class="doc-row">
            <div class="doc-main-desc">
              <div>
              <h2 class="service-title">РЕСТАВРАЦІЯ ФОТО</h2>
              <!-- <p class="doc-main-subtitle">Відновимо старі та пошкоджені фото акуратно та природно</p> -->
              <p class="doc-main-subtitle">Відновимо старі та пошкоджені фото</p>

              <ul class="services-list">
                <li class="doc-item">Приберемо подряпини, заломи та плями</li>
                <li class="doc-item">Повернемо чіткість і тон (колір/ч-б)</li>
                <li class="doc-item">Підготуємо файл для друку</li>
              </ul>

              <div class="doc-meta" aria-label="Умови послуги">
                <span class="doc-chip doc-chip--price">від 200 грн</span>
                <span class="doc-chip doc-chip--time">1–2 дні</span>
                <span class="doc-chip doc-chip--file">файл на флешку</span>
              </div>
              </div>

              <a class="doc-more" href="/ua/restore/">
                <span class="doc-more__label">Детальніше</span>
                <span class="doc-more__text">про реставрацію</span>
              </a>
            </div>

            <div class="doc-row-media">
              <img src="/images/rest.jpg" alt="Реставрація фото: до та після"  loading="lazy" />

              <div class="doc-tags" aria-hidden="true">
                <span class="doc-tag doc-tag--before">До</span>
                <span class="doc-tag doc-tag--after">Після</span>
              </div>
            </div>
          </div>        
    </section>

    <div class="main-page-line"></div>


    <section class="doc-info">
  <div class="doc-row" data-title="Друк фотографій">
    <div class="doc-main-desc">
      <div>
      <h2 class="service-title">ДРУК ФОТОГРАФІЙ</h2>

      <p class="doc-main-subtitle">Друк фото на якісному фотопапері</p>

      <ul class="services-list">
        <li class="doc-item">Популярні формати: 10×15, 13×18, 15×21 та інші</li>
        <li class="doc-item">Матова або глянцева поверхня на вибір</li>
        <li class="doc-item">Корекція яскравості/контрасту за потреби</li>
        <!-- <li class="doc-item">Друк з телефону (Viber/Telegram) або з флешки</li> -->
      </ul>

      <div class="doc-meta" aria-label="Умови послуги">
        <span class="doc-chip doc-chip--price">від 6 грн / шт</span>
        <span class="doc-chip doc-chip--time">від 5 хв</span>
        <span class="doc-chip doc-chip--file">з телефону / флешки</span>
      </div>
      </div>

      <a class="doc-more" href="/ua/print/">
        <span class="doc-more__label">Детальніше</span>
        <span class="doc-more__text">про друк фотографій</span>
      </a>
    </div>

    <div class="print-img">
      <img src="/images/print.jpg" alt="Друк фотографій" height="345" loading="lazy" />
    </div>
  </div>
</section>


